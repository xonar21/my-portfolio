---
import VisitorStats from '../VisitorStats';

interface Props {
	title: string;
	labels: {
		labelOnline: string;
		labelToday: string;
		labelTotal: string;
		labelRegions: string;
		loading: string;
		noData: string;
	};
}

const { title, labels } = Astro.props;
---

<section
	id="visitors"
	class="scroll-mt-24 border-t border-black/5 py-24 dark:border-white/10 md:py-28"
>
	<div class="mx-auto max-w-6xl px-6">
		<h2
			class="text-balance text-[clamp(2.125rem,4.5vw,3.25rem)] font-semibold leading-[1.07] tracking-[-0.028em] text-[#1d1d1f] dark:text-[#f5f5f7]"
		>
			{title}
		</h2>
		<VisitorStats client:visible labels={labels} />
	</div>
</section>
