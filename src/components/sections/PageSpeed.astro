---
import PageSpeedSection from '../PageSpeedSection';

interface Props {
	title: string;
	labels: {
		lead: string;
		tabMobile: string;
		tabDesktop: string;
		labelPerformance: string;
		labelAccessibility: string;
		labelBestPractices: string;
		labelSeo: string;
		lastChecked: string;
		refresh: string;
		loading: string;
		noKey: string;
	};
}

const { title, labels } = Astro.props;
---

<section
	id="performance"
	class="scroll-mt-24 border-t border-black/5 py-24 dark:border-white/10 md:py-28"
>
	<div class="mx-auto max-w-6xl px-6">
		<h2
			class="text-balance text-[clamp(2.125rem,4.5vw,3.25rem)] font-semibold leading-[1.07] tracking-[-0.028em] text-[#1d1d1f] dark:text-[#f5f5f7]"
		>
			{title}
		</h2>
		<PageSpeedSection client:visible labels={labels} />
	</div>
</section>
