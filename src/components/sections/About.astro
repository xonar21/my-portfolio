---
interface Props {
  title: string;
  body: string;
}

const { title, body } = Astro.props;
---

<section
  id="about"
  class="scroll-mt-24 border-t border-black/5 py-24 dark:border-white/10 md:py-28"
>
  <div class="mx-auto max-w-6xl px-6">
    <h2
      class="text-balance text-[clamp(2.125rem,4.5vw,3.25rem)] font-semibold leading-[1.07] tracking-[-0.028em] text-[#1d1d1f] dark:text-[#f5f5f7]"
    >
      {title}
    </h2>
    <div
      class="mt-10 max-w-4xl rounded-3xl border border-black/5 bg-white/70 p-8 shadow-sm backdrop-blur-md dark:border-white/10 dark:bg-white/[0.04] md:p-12"
    >
      <p
        class="text-pretty text-[21px] font-normal leading-[1.5] tracking-[-0.015em] text-neutral-700 md:text-[24px] md:leading-[1.4584] dark:text-neutral-300"
      >
        {body}
      </p>
    </div>
  </div>
</section>
